{
	"name": "kitto",
	"version": "1.1.0",
	"author": "Matt Pilott",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mattpilott/kitto.git"
	},
	"devDependencies": {
		"@eslint/compat": "2.0.3",
		"@eslint/js": "10.0.1",
		"@microsoft/api-documenter": "^7.29.7",
		"@microsoft/api-extractor": "^7.57.7",
		"@playwright/test": "1.58.2",
		"@sveltejs/adapter-auto": "7.0.1",
		"@sveltejs/kit": "2.54.0",
		"@sveltejs/package": "2.5.7",
		"@sveltejs/vite-plugin-svelte": "6.2.4",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/svelte": "5.3.1",
		"@types/node": "25.5.0",
		"@vitest/coverage-v8": "4.1.0",
		"eslint": "10.0.3",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.15.2",
		"globals": "17.4.0",
		"jsdom": "28.1.0",
		"prettier": "3.8.1",
		"prettier-plugin-svelte": "3.5.1",
		"publint": "0.3.18",
		"svelte": "5.53.11",
		"svelte-check": "4.4.5",
		"tinydate": "1.3.0",
		"typedoc": "0.28",
		"typedoc-github-theme": "0.4.0",
		"typescript": "5.9.3",
		"typescript-eslint": "8.57.0",
		"vite": "8.0.0",
		"vitest": "4.1.0"
	},
	"peerDependencies": {
		"svelte": "5",
		"lightningcss": "1"
	},
	"exports": {
		".": {
			"types": "./dist/vanilla/index.d.ts",
			"default": "./dist/vanilla/index.js"
		},
		"./vanilla": {
			"types": "./dist/vanilla/index.d.ts",
			"default": "./dist/vanilla/index.js"
		},
		"./svelte": {
			"types": "./dist/svelte/index.d.ts",
			"svelte": "./dist/svelte/index.js",
			"default": "./dist/svelte/index.js"
		},
		"./lightningcss": {
			"types": "./dist/lightningcss/index.d.ts",
			"default": "./dist/lightningcss/index.js"
		},
		"./reset": "./dist/styles/reset.css",
		"./unify": "./dist/styles/unify.css"
	},
	"bugs": {
		"url": "https://github.com/mattpilott/kitto/issues"
	},
	"description": "A unique blend of tree-shakeable items for any web expedition",
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"homepage": "https://github.com/mattpilott/kitto#readme",
	"keywords": [
		"svelte",
		"utilities"
	],
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"bench": "vitest bench",
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"docs": "typedoc",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"coverage": "vitest run --coverage",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test"
	},
	"sideEffects": [
		"**/*.css"
	],
	"main": "./dist/vanilla/index.js",
	"type": "module",
	"types": "./dist/vanilla/index.d.ts"
}
